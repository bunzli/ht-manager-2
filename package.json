{
  "name": "ht-manager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run kill-ports && npm-run-all --parallel dev:server dev:client",
    "dev:server": "cd server && npx tsx watch src/index.ts",
    "dev:client": "cd client && npx vite",
    "kill-ports": "node scripts/kill-ports.mjs",
    "build": "npm run build:client && npm run build:server",
    "build:server": "cd server && npx tsc",
    "build:client": "cd client && npx vite build",
    "db:migrate": "cd server && DATABASE_URL=\"file:./prisma/dev.db\" npx prisma migrate dev",
    "garage": "cd client && npm run storybook",
    "lint": "eslint 'client/src/**/*.{ts,tsx}' 'server/src/**/*.ts'",
    "lint:fix": "eslint --fix 'client/src/**/*.{ts,tsx}' 'server/src/**/*.ts'",
    "format": "prettier --write 'client/src/**/*.{ts,tsx}' 'server/src/**/*.ts'"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "react-router-dom": "^7.14.1"
  }
}
